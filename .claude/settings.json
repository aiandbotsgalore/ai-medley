{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const f=process.env.CLAUDE_TOOL_INPUT_FILE_PATH||''; if(f.includes('.env')){console.error('Blocked: editing env files is not allowed');process.exit(2);}\"",
            "block_on_error": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const f=process.env.CLAUDE_TOOL_INPUT_FILE_PATH||''; if(f.match(/\\.tsx?$/)){require('child_process').execSync('npm run lint',{stdio:'inherit',cwd:'G:/ai-medley--main'})}\""
          }
        ]
      }
    ]
  }
}
